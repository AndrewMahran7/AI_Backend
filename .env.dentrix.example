# ════════════════════════════════════════════════════════════════════════
#  Dentrix Local Agent  —  Environment Configuration
# ════════════════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in the values for your dental office.
#  All values are loaded at startup via python-dotenv.
#
# ────────────────────────────────────────────────────────────────────────

# ── Dentrix ODBC Connection ─────────────────────────────────────────────
#
#  Option A: DSN-based connection (recommended if you set up an ODBC DSN)
#    DENTRIX_ODBC_DSN=DentrixDB
#
#  Option B: Driver-based connection (no DSN required)
#    Fill in DRIVER, SERVER, DATABASE below.

DENTRIX_ODBC_DSN=
DENTRIX_ODBC_DRIVER={SQL Server}
DENTRIX_ODBC_SERVER=localhost\DENTRIX
DENTRIX_ODBC_DATABASE=DENTRIX
DENTRIX_ODBC_USERNAME=
DENTRIX_ODBC_PASSWORD=
DENTRIX_ODBC_EXTRA=
DENTRIX_ODBC_TIMEOUT=30

# ── Backend API ─────────────────────────────────────────────────────────
#  URL of the remote FastAPI backend that receives ingested records.

DENTRIX_BACKEND_URL=http://localhost:8000
DENTRIX_API_PREFIX=/api/v1
DENTRIX_API_KEY=

# ── Sync Behaviour ──────────────────────────────────────────────────────

DENTRIX_BATCH_SIZE=100
DENTRIX_MAX_RETRIES=3
DENTRIX_BACKOFF_BASE=2.0
DENTRIX_HTTP_TIMEOUT=60

# ── Logging ─────────────────────────────────────────────────────────────
#  Set to empty string to disable file logging.

DENTRIX_LOG_FILE=dentrix_sync.log
